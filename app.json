{
  "expo": {
    "name": "Meridian: Health Insights",
    "slug": "meridian",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0F1A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.teamam.meridian",
      "backgroundColor": "#0D0F1A",
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification",
          "remote-notification"
        ],
        "ITSAppUsesNonExemptEncryption": false
      },
      "buildNumber": "3",
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": [
              "CA92.1"
            ]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": [
              "CA92.1"
            ]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D0F1A"
      },
      "package": "com.teamam.meridian"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "backgroundColor": "#0D0F1A",
      "name": "Meridian: Health Insights"
    },
    "plugins": [
      "expo-font",
      "expo-sharing",
      "expo-notifications"
    ],
    "extra": {
      "eas": {
        "projectId": "3bdca75b-5842-4863-82ba-a81014640190"
      }
    },
    "owner": "hsikk"
  }
}
