{
  "expo": {
    "name": "Meridian: Body Pattern Intelligence",
    "slug": "meridian",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0F1A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.teamam.meridian",
      "backgroundColor": "#0D0F1A"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D0F1A"
      },
      "package": "com.teamam.meridian"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "backgroundColor": "#0D0F1A",
      "name": "Meridian: Body Pattern Intelligence"
    },
    "plugins": [
      "expo-font"
    ]
  }
}
